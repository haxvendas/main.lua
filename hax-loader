local function getBaseFolder(path)
    local current = workspace
    for _, name in path do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end

local function nameContainsAll(haystack, words)
    for _, word in words do
        if not string.find(haystack, word, 1, true) then
            return false
        end
    end
    return true
end

local function getBrainrotDisplayName(rendered)
    for _, v in rendered:GetChildren() do
        local n = v.Name
        if n ~= "Root" and n ~= "UniversalHighlight" and n ~= "UniversalBillboard" then
            return n
        end
    end
    return "?"
end

local function getTargetObject(obj, isPerInstance)
    if isPerInstance then
        return obj
    end
    if obj:IsA("BasePart") and obj.Parent then
        return obj.Parent
    end
    return obj
end

local function createHighlight(adornee, color)
    if adornee:FindFirstChild("UniversalHighlight") then return end
    local h = Instance.new("Highlight")
    h.Name = "UniversalHighlight"
    h.Adornee = adornee
    h.FillColor = color
    h.OutlineColor = Color3.new(1,1,1)
    h.FillTransparency = 0.45
    h.OutlineTransparency = 0.1
    h.Parent = adornee
end

local function createDistanceBillboard(adornee, labelText, emoji, color)
    if adornee:FindFirstChild("UniversalBillboard") then return end

    local bb = Instance.new("BillboardGui")
    bb.Name = "UniversalBillboard"
    bb.Size = UDim2.new(0, 260, 0, 70)
    bb.StudsOffset = Vector3.new(0, 4, 0)
    bb.AlwaysOnTop = true
    bb.Parent = adornee

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextStrokeTransparency = 0
    txt.TextStrokeColor3 = Color3.new(0,0,0)
    txt.TextScaled = true
    txt.Font = Enum.Font.GothamBold
    txt.Parent = bb

    -- Heartbeat é bem mais eficiente que loop com task.wait(0.4)
    local conn
    conn = game:GetService("RunService").Heartbeat:Connect(function()
        if not adornee.Parent then
            conn:Disconnect()
            return
        end
        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local dist = (hrp.Position - adornee:GetPivot().Position).Magnitude
        txt.Text = string.format("%s %s\n📏 %d studs", emoji, labelText, math.floor(dist))
    end)

    table.insert(connections, conn)
end

