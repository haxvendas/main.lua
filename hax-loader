}
local vipNames2 = { "SEC 1", "2", "3", "4" }

local curIndex2 = 0
local isTweening2 = false
local isAutoLooping = false -- Controle do Loop
local lastInputTime2 = 0
local DEBOUNCE2 = 0.12
local activeTween2 = nil
local statusLabel2 = nil -- Será definido na criação da GUI

-- =============================================
-- FUNÇÕES DE LÓGICA
-- =============================================

-- Atualiza o texto na tela
local function updateStatus2()
    if not statusLabel2 then return end
    if curIndex2 == 0 then
        statusLabel2.Text = "R → Iniciar Auto Loop"
    else
        local loopStatus = isAutoLooping and "<font color='rgb(100,255,100)'> [LOOP ATIVO]</font>" or ""
        statusLabel2.Text = "R → Alternar Loop" .. loopStatus .. "\n" ..
                            "<font color='rgb(220,200,255)'>Zona " .. curIndex2 .. "/" .. #vipPos2 ..
                            " - " .. (vipNames2[curIndex2] or "?") .. "</font>" ..
                            (isTweening2 and "\n<font color='rgb(255,180,100)'>Movendo...</font>" or "")
    end
end

-- Função de Teleporte Suave
local function smoothFastTP2(targetIndex)
    if tick() - lastInputTime2 < DEBOUNCE2 then return end
    
    if activeTween2 then 
        activeTween2:Cancel() 
        activeTween2 = nil
    end

    if targetIndex > #vipPos2 then targetIndex = 1 end
    if targetIndex < 1 then targetIndex = #vipPos2 end
    
    local char = plr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    isTweening2 = true
    lastInputTime2 = tick()
    curIndex2 = targetIndex 
    updateStatus2()

    local targetPos = vipPos2[targetIndex] + Vector3.new(0, 4, 0)
    local distance = (hrp.Position - targetPos).Magnitude
    local tweenTime = distance / 1400

    -- Notificação opcional (remova se poluir muito o chat no loop)
    if not isAutoLooping then
        notify("→ SEC " .. targetIndex, Color3.fromRGB(200, 150, 255))
    end

    local tweenInfo = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear)

    activeTween2 = TS:Create(hrp, tweenInfo, {
        CFrame = CFrame.new(targetPos) * CFrame.Angles(0, math.rad(180), 0)
    })

    activeTween2:Play()

    activeTween2.Completed:Connect(function(playbackState)
        if playbackState == Enum.PlaybackState.Completed then
            isTweening2 = false
            activeTween2 = nil
            updateStatus2()
        end
    end)
end

-- Função que executa o Loop Infinito
local function startAutoLoop()
    if isAutoLooping then return end
    isAutoLooping = true
    notify("AUTO-LOOP: LIGADO", Color3.fromRGB(100, 255, 100))
    updateStatus2()

    while isAutoLooping do
        local nextIndex = curIndex2 + 1
        if nextIndex > #vipPos2 then nextIndex = 1 end
        
        smoothFastTP2(nextIndex)

        -- Espera importante: Aguarda o Tween chegar no destino antes de ir para o próximo
        if activeTween2 then
            activeTween2.Completed:Wait()
        end
        
        task.wait(0.2) -- Pausa de descanso entre cada ponto
    end
    
    notify("AUTO-LOOP: DESLIGADO", Color3.fromRGB(255, 100, 100))
    updateStatus2()
end

