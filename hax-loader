end

local function processFolder(folder, target)
    if not folder then return end

    local isPerInstance = target.PerInstance == true

    for _, child in folder:GetChildren() do
        local objName = child.Name
        local matched = false

        if target.Match then
            matched = (objName == target.Match)
        elseif target.Contains then
            matched = nameContainsAll(objName, target.Contains)
        end

        if not matched then continue end

        local realObj = getTargetObject(child, isPerInstance)
        if detected[realObj] then continue end
        detected[realObj] = true

        local cfg = CONFIG[target.Type]

        -- Label logic
        local label
        if target.IsBrainrot then
            label = target.Type:upper() .. " – " .. getBrainrotDisplayName(child)
        elseif string.find(objName, "LuckyBlock", 1, true) then
            label = target.Type:upper() .. " LUCKY BOX"
        else
            label = target.Label or (target.Type:upper() .. " EVENT")
        end

        createHighlight(realObj, cfg.Color)
        createDistanceBillboard(realObj, label, cfg.Emoji, cfg.Color)

        notifyEvent(cfg.Emoji .. " " .. label .. " DETECTADO!")
    end
end

