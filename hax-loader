local function setupAutoDeposit()
    local function activatePrompt(prompt)
        if prompt:IsA("ProximityPrompt") then
            prompt.HoldDuration = 0
            prompt.RequiresLineOfSight = false

            task.spawn(function()
                -- O loop verifica se o prompt ainda é válido e se está visível/ativo
                while prompt and prompt.Parent and prompt.Enabled do
                    fireproximityprompt(prompt)
                    task.wait(0.2)
                end
            end)
        end
    end

    -- Função para escanear e aplicar nos alvos
    local function scanAndApply()
        -- Procura CandyGramStation
        local vMap = workspace:FindFirstChild("ValentinesMap")
        if vMap then
            local station = vMap:FindFirstChild("CandyGramStation")
            if station then
                for _, p in pairs(station:GetDescendants()) do activatePrompt(p) end
                station.DescendantAdded:Connect(activatePrompt)
            end
        end

        -- Procura GhostCannon (Caminho específico que você passou)
        local pMap = workspace:FindFirstChild("PhantomMap")
        if pMap then
            local cannon = pMap:FindFirstChild("GhostCannon")
            if cannon and cannon:FindFirstChild("Part") and cannon.Part:FindFirstChild("Prompts") then
                local prompt = cannon.Part.Prompts:FindFirstChildOfClass("ProximityPrompt")
                if prompt then activatePrompt(prompt) end
            end
        end
    end

    -- Executa a verificação inicial
    scanAndApply()

    -- Fica de olho se os mapas/pastas forem deletados e recriados
    workspace.ChildAdded:Connect(function(child)
        if child.Name == "ValentinesMap" or child.Name == "PhantomMap" then
            task.wait(1) -- Pequeno delay para garantir que os filhos do mapa carregaram
            scanAndApply()
        end
    end)
end

