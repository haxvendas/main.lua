local MAGNET_DISTANCE = 100000
local COOLDOWN = 0.01

local lastTouch = {}

local function getHRP()
    local char = game.Players.LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function tryTouch(part, hrp)
    if not part or not hrp or not part:IsA("BasePart") then return end
    
    local dist = (part.Position - hrp.Position).Magnitude

    if dist <= MAGNET_DISTANCE then
        if not lastTouch[part] or tick() - lastTouch[part] > COOLDOWN then
            firetouchinterest(hrp, part, 0)
            firetouchinterest(hrp, part, 1)
            lastTouch[part] = tick()
        end
    end
end

