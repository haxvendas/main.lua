-- Script Speed Anti-Reset com GUI na TELA para Roblox
-- GUI arrastável com Slider, Toggle e Botões
-- Velocidade NÃO reseta com tools ou respawn

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local speed = 50  -- Velocidade inicial
local isEnabled = true  -- Ativado por padrão
local currentHumanoid = nil
local connection = nil

-- Cria GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "SpeedGUI"
screenGui.Parent = playerGui
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(0, 250, 0, 200)
mainFrame.Position = UDim2.new(0, 10, 0, 10)
mainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true  -- Arrastável!
mainFrame.Parent = screenGui

-- Cantos arredondados
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = mainFrame

-- Título
local title = Instance.new("TextLabel")
title.Name = "Title"
title.Size = UDim2.new(1, 0, 0, 40)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "HAX SPEED "
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

-- Status Toggle
local toggleBtn = Instance.new("TextButton")
toggleBtn.Name = "ToggleBtn"
toggleBtn.Size = UDim2.new(0.9, 0, 0, 35)
toggleBtn.Position = UDim2.new(0.05, 0, 0, 45)
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
toggleBtn.Text = "✅ ATIVADO"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.TextScaled = true
toggleBtn.Font = Enum.Font.Gotham
toggleBtn.Parent = mainFrame

local toggleCorner = Instance.new("UICorner")
toggleCorner.CornerRadius = UDim.new(0, 8)
toggleCorner.Parent = toggleBtn

-- Velocidade Atual
local speedLabel = Instance.new("TextLabel")
speedLabel.Name = "SpeedLabel"
speedLabel.Size = UDim2.new(1, 0, 0, 30)
speedLabel.Position = UDim2.new(0, 0, 0, 85)
speedLabel.BackgroundTransparency = 1
speedLabel.Text = "Velocidade: " .. speed
speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
speedLabel.TextScaled = true
speedLabel.Font = Enum.Font.Gotham
speedLabel.Parent = mainFrame

-- Botão +10
local plusBtn = Instance.new("TextButton")
plusBtn.Name = "PlusBtn"
plusBtn.Size = UDim2.new(0.45, 0, 0, 30)
plusBtn.Position = UDim2.new(0.05, 0, 0, 120)
plusBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
plusBtn.Text = "+10"
plusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
plusBtn.TextScaled = true
plusBtn.Font = Enum.Font.GothamBold
plusBtn.Parent = mainFrame

local plusCorner = Instance.new("UICorner")
plusCorner.CornerRadius = UDim.new(0, 8)
plusCorner.Parent = plusBtn

-- Botão -10
local minusBtn = Instance.new("TextButton")
minusBtn.Name = "MinusBtn"
minusBtn.Size = UDim2.new(0.45, 0, 0, 30)
minusBtn.Position = UDim2.new(0.5, 0, 0, 120)
minusBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
minusBtn.Text = "-10"
minusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
minusBtn.TextScaled = true
minusBtn.Font = Enum.Font.GothamBold
minusBtn.Parent = mainFrame

local minusCorner = Instance.new("UICorner")
minusCorner.CornerRadius = UDim.new(0, 8)
minusCorner.Parent = minusBtn

-- Botão Reset
local resetBtn = Instance.new("TextButton")
resetBtn.Name = "ResetBtn"
resetBtn.Size = UDim2.new(0.9, 0, 0, 30)
resetBtn.Position = UDim2.new(0.05, 0, 0, 155)
resetBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
resetBtn.Text = "🔄 RESET (16)"
resetBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
resetBtn.TextScaled = true
resetBtn.Font = Enum.Font.GothamBold
resetBtn.Parent = mainFrame

local resetCorner = Instance.new("UICorner")
resetCorner.CornerRadius = UDim.new(0, 8)
resetCorner.Parent = resetBtn

-- Efeito hover nos botões
local function tweenButton(btn, color)
    local tween = TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color})
    tween:Play()
end

plusBtn.MouseEnter:Connect(function() tweenButton(plusBtn, Color3.fromRGB(0, 255, 0)) end)
plusBtn.MouseLeave:Connect(function() tweenButton(plusBtn, Color3.fromRGB(0, 200, 0)) end)
minusBtn.MouseEnter:Connect(function() tweenButton(minusBtn, Color3.fromRGB(255, 0, 0)) end)
minusBtn.MouseLeave:Connect(function() tweenButton(minusBtn, Color3.fromRGB(200, 0, 0)) end)
resetBtn.MouseEnter:Connect(function() tweenButton(resetBtn, Color3.fromRGB(255, 200, 0)) end)
resetBtn.MouseLeave:Connect(function() tweenButton(resetBtn, Color3.fromRGB(255, 165, 0)) end)

-- Funções principais
local function applySpeed(humanoid)
    if not isEnabled then return end
    humanoid.WalkSpeed = speed
    
    -- Anti-reset: monitora e corrige
    if connection then connection:Disconnect() end
    connection = humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if humanoid.WalkSpeed ~= speed then
            humanoid.WalkSpeed = speed
        end
    end)
end

local function updateLabel()
    speedLabel.Text = "Velocidade: " .. speed
end

local function onCharacterAdded(character)
    local humanoid = character:WaitForChild("Humanoid")
    currentHumanoid = humanoid
    if isEnabled then
        applySpeed(humanoid)
    end
end

-- Eventos dos botões
toggleBtn.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    toggleBtn.Text = isEnabled and "✅ ATIVADO" or "❌ DESATIVADO"
    toggleBtn.BackgroundColor3 = isEnabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    
    if currentHumanoid and isEnabled then
        applySpeed(currentHumanoid)
    elseif currentHumanoid then
        currentHumanoid.WalkSpeed = 16
        if connection then connection:Disconnect() end
    end
end)

plusBtn.MouseButton1Click:Connect(function()
    speed = speed + 10
    updateLabel()
    if isEnabled and currentHumanoid then
        currentHumanoid.WalkSpeed = speed
    end
end)

minusBtn.MouseButton1Click:Connect(function()
    speed = speed - 10
    if speed < 16 then speed = 16 end
    updateLabel()
    if isEnabled and currentHumanoid then
        currentHumanoid.WalkSpeed = speed
    end
end)

resetBtn.MouseButton1Click:Connect(function()
    speed = 16
    updateLabel()
    if isEnabled and currentHumanoid then
        currentHumanoid.WalkSpeed = speed
    end
end)

-- Conecta respawn
player.CharacterAdded:Connect(onCharacterAdded)

-- Aplica atual
if player.Character then
    onCharacterAdded(player.Character)
end

print("🚀 Speed GUI ativado! Arraste a janela e use os botões.")
